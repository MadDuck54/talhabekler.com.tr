---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';
import Gridlines from '../components/Gridlines.astro';
import Topbar from '../components/Topbar.astro';
import Foot from '../components/Foot.astro';

export interface Props {
  title: string;
  description: string;
  ogTitle?: string;
  ogDescription?: string;
  ogType?: 'website' | 'article' | 'profile';
  ogImage?: string;
  ogImageAlt?: string;
  canonical?: string;
  /** topbar nav: aktif bölüm */
  section: 'cv' | 'blog';
  /** topbar id breadcrumb (ör. "cv/talha-bekler" veya "blog/talha-bekler") */
  breadcrumb: string;
  /** topbar id sonrası sürüm/sayaç metni — TR */
  metaTr?: string;
  /** topbar id sonrası sürüm/sayaç metni — EN */
  metaEn?: string;
  /** dil switch'ini göster (CV'de açık, blog'da kapalı) */
  showLangToggle?: boolean;
  /** schema.org JSON-LD bloğu (opsiyonel ek) */
  jsonLd?: unknown;
  /** footer ok metni — TR */
  footOkTr?: string;
  /** footer ok metni — EN */
  footOkEn?: string;
  /** sayfanın varsayılan dili — html lang ve og:locale için */
  htmlLang?: 'tr' | 'en';
  /** og:locale — verilmezse htmlLang'den türetilir */
  ogLocale?: string;
  /** hreflang alternates — örn. [{ code: 'tr', href: '...' }, { code: 'en', href: '...' }, { code: 'x-default', href: '...' }] */
  alternates?: Array<{ code: string; href: string }>;
}

const {
  title,
  description,
  ogTitle = title,
  ogDescription = description,
  ogType = 'website',
  ogImage = '/og/default.png',
  ogImageAlt = title,
  canonical,
  section,
  breadcrumb,
  metaTr,
  metaEn,
  showLangToggle = true,
  jsonLd,
  footOkTr = 'belge sonu',
  footOkEn = 'end of document',
  htmlLang = 'tr',
  ogLocale,
  alternates = [],
} = Astro.props;

const resolvedOgLocale = ogLocale ?? (htmlLang === 'en' ? 'en_US' : 'tr_TR');

const canonicalUrl = canonical ?? new URL(Astro.url.pathname.replace(/\/$/, '') || '/', Astro.site).toString();
const ogImageUrl = new URL(ogImage, Astro.site).toString();

// JSON-LD breakout (`</script>`) ve HTML metakarakter koruması — defansif unicode-escape
const jsonLdString = jsonLd
  ? JSON.stringify(jsonLd)
      .replace(/</g, '\\u003c')
      .replace(/>/g, '\\u003e')
      .replace(/&/g, '\\u0026')
  : null;
---

<!doctype html>
<html lang={htmlLang} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Talha Bekler" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="canonical" href={canonicalUrl} />

    {alternates.map((alt) => (
      <link rel="alternate" hreflang={alt.code} href={alt.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Talha Bekler" />
    <meta property="og:locale" content={resolvedOgLocale} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="alternate" type="application/rss+xml" title="Talha Bekler — blog" href="/rss.xml" />

    {jsonLdString && (
      <script type="application/ld+json" set:html={jsonLdString} />
    )}

    {/* tema başlatıcı — boyamadan ÖNCE çalışır, FOUC engellenir.
        kayıtlı tercih > işletim sistemi tercihi (prefers-color-scheme) > koyu */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored === 'light' || stored === 'dark'
            ? stored
            : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
          var m = document.querySelector('meta[name="theme-color"]');
          if (m) m.setAttribute('content', theme === 'light' ? '#f4f0e8' : '#0a0a0a');
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <Gridlines />
    <main>
      <Topbar
        section={section}
        breadcrumb={breadcrumb}
        metaTr={metaTr}
        metaEn={metaEn}
        showLangToggle={showLangToggle}
        lang={showLangToggle ? undefined : htmlLang}
      />
      <slot />
      <Foot okTr={footOkTr} okEn={footOkEn} lang={showLangToggle ? undefined : htmlLang} />
    </main>

    <script is:inline>
      // dil değiştirici — orijinal davranış birebir korundu
      document.querySelectorAll('button[data-set]').forEach((b) => {
        b.addEventListener('click', () => {
          const l = b.dataset.set;
          document.documentElement.lang = l;
          document.querySelectorAll('button[data-set]').forEach((x) =>
            x.classList.toggle('on', x.dataset.set === l),
          );
          document.querySelectorAll('[data-tr],[data-en]').forEach((el) => {
            el.hidden = !el.hasAttribute('data-' + l);
          });
        });
      });

      // tema değiştirici — koyu/açık geçişi, tercih localStorage'da kalıcı
      (function () {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        const meta = document.querySelector('meta[name="theme-color"]');
        const sync = (t) => {
          btn.setAttribute('aria-pressed', t === 'light' ? 'true' : 'false');
          if (meta) meta.setAttribute('content', t === 'light' ? '#f4f0e8' : '#0a0a0a');
        };
        sync(document.documentElement.dataset.theme === 'light' ? 'light' : 'dark');
        btn.addEventListener('click', () => {
          const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem('theme', next); } catch (e) {}
          sync(next);
        });
      })();
    </script>
  </body>
</html>
