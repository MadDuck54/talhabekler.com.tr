---
import BaseLayout from '../layouts/BaseLayout.astro';
import { author, SITE_URL } from '../lib/identity';

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: author.name,
  jobTitle: 'Geliştirici',
  description:
    'AI iş akışları ve iç sistemler üzerine geliştirici. Üretim ve operasyon işletmeleri için ERP/MES, depo yönetim, ajan orkestrasyonu üretir.',
  url: author.url,
  image: `${SITE_URL}/og/default.png`,
  sameAs: author.sameAs,
  knowsAbout: [
    'Laravel', 'PHP', 'Node.js', 'Vue.js', 'React', 'Next.js', 'Astro', 'TypeScript',
    'PostgreSQL', 'MySQL', 'Redis',
    'Linux', 'Docker', 'Caddy', 'Cloudflare', 'Tailscale', 'systemd',
    'ERP', 'MES', 'WMS',
    'AI workflow', 'Multi-agent systems', 'Claude Code',
  ],
  knowsLanguage: [
    { '@type': 'Language', name: 'Türkçe', alternateName: 'tr' },
    { '@type': 'Language', name: 'English', alternateName: 'en' },
  ],
};
---

<BaseLayout
  title="Talha Bekler — AI iş akışları ve iç sistemler"
  description="Talha Bekler — AI iş akışları ve iç sistemler üzerine geliştirici. Üretim ve operasyon işletmeleri için ERP/MES, depo yönetim, ajan orkestrasyonu üretir."
  ogTitle="Talha Bekler — AI iş akışları ve iç sistemler"
  ogDescription="AI iş akışları ve iç sistemler üzerine geliştirici. ERP/MES, depo yönetim, ajan orkestrasyonu, self-hosted altyapı."
  ogType="profile"
  section="cv"
  breadcrumb="cv/talha-bekler"
  metaTr="sürüm 2026.04"
  metaEn="build 2026.04"
  jsonLd={personJsonLd}
>
  <section class="hero">
    <div class="meta">
      <span data-tr>belge</span><span data-en hidden>document</span>
      <span class="v">CV—001</span>
      <span data-tr>tarih</span><span data-en hidden>date</span>
      <span class="v">2026·04·26</span>
      <span data-tr>durum</span><span data-en hidden>status</span>
      <span class="v" data-tr>aktif</span><span class="v" data-en hidden>live</span>
    </div>
    <h1 class="name"><span class="lt">[</span>talha bekler<span class="lt">]</span><span class="cur"></span></h1>
    <div class="role">
      <span data-tr>AI iş akışları ve iç sistemler üzerine geliştirici</span>
      <span data-en hidden>developer focused on AI workflows and internal systems</span>
    </div>
  </section>

  <section class="row">
    <h2 class="lbl">
      <span class="num">01</span>
      <span data-tr>tanım</span><span data-en hidden>profile</span>
    </h2>
    <div class="body">
      <p class="lede" data-tr>
        Üretim ve operasyon işletmeleri için <span class="hl">iç araçlar</span>
        yazıyorum. Web ve sunucudan sahadaki donanıma, oradan da AI iş
        akışlarına kadar farklı katmanlarda çalışmayı seviyorum.
      </p>
      <p class="lede" data-en hidden>
        I build <span class="hl">internal tools</span> for manufacturing and
        operations. I enjoy moving between layers — web, servers,
        on-floor hardware and AI workflows.
      </p>
    </div>
  </section>

  <section class="row">
    <h2 class="lbl">
      <span class="num">02</span>
      <span data-tr>uzmanlık</span><span data-en hidden>focus</span>
    </h2>
    <div class="body">
      <div class="focus">
        <dl><dt>backend</dt><dd>
          <button class="chip" data-tag="laravel">laravel</button>
          <button class="chip" data-tag="php">php</button>
          <button class="chip" data-tag="node">node</button>
          <button class="chip" data-tag="queue">queue jobs</button>
          <button class="chip" data-tag="multitenant">multi-tenant</button>
          <button class="chip" data-tag="sanctum">sanctum</button>
        </dd></dl>
        <dl><dt>frontend</dt><dd>
          <button class="chip" data-tag="vue">vue 3</button>
          <button class="chip" data-tag="react">react</button>
          <button class="chip" data-tag="next">next.js</button>
          <button class="chip" data-tag="inertia">inertia</button>
          <button class="chip" data-tag="livewire">livewire</button>
          <button class="chip" data-tag="alpine">alpine</button>
          <button class="chip" data-tag="ts">typescript</button>
          <button class="chip" data-tag="astro">astro</button>
          <button class="chip" data-tag="tailwind">tailwind</button>
        </dd></dl>
        <dl><dt>data</dt><dd>
          <button class="chip" data-tag="postgres">postgres</button>
          <button class="chip" data-tag="mysql">mysql</button>
          <button class="chip" data-tag="sqlite">sqlite</button>
          <button class="chip" data-tag="redis">redis</button>
          <button class="chip" data-tag="drizzle">drizzle</button>
          <button class="chip" data-tag="eloquent">eloquent</button>
        </dd></dl>
        <dl><dt>infra</dt><dd>
          <button class="chip" data-tag="linux">linux</button>
          <button class="chip" data-tag="docker">docker</button>
          <button class="chip" data-tag="caddy">caddy</button>
          <button class="chip" data-tag="cloudflare">cloudflare</button>
          <button class="chip" data-tag="tailscale">tailscale</button>
          <button class="chip" data-tag="systemd">systemd</button>
        </dd></dl>
        <dl><dt>ai</dt><dd>
          <button class="chip" data-tag="claude-code">claude code subagents</button>
          <button class="chip" data-tag="vercel-ai">vercel ai sdk</button>
          <button class="chip" data-tag="multi-provider">multi-provider</button>
          <button class="chip" data-tag="agent-orch">agent orchestration</button>
        </dd></dl>
        <dl><dt>hardware</dt><dd>
          <button class="chip" data-tag="tspl">tspl yazıcılar</button>
          <button class="chip" data-tag="qr">qr</button>
          <button class="chip" data-tag="industrial">endüstriyel entegrasyon</button>
        </dd></dl>
        <dl><dt>design</dt><dd>
          <button class="chip" data-tag="brand"><span data-tr>marka kimliği</span><span data-en hidden>brand identity</span></button>
          <button class="chip" data-tag="design-system"><span data-tr>tasarım sistemleri</span><span data-en hidden>design systems</span></button>
          <button class="chip" data-tag="typography"><span data-tr>tipografi</span><span data-en hidden>typography</span></button>
          <button class="chip" data-tag="field-ux"><span data-tr>saha-bazlı ux</span><span data-en hidden>field-driven ux</span></button>
        </dd></dl>
        <dl><dt>method</dt><dd>
          <button class="chip" data-tag="internal-tools"><span data-tr>iç araçlar</span><span data-en hidden>internal tools</span></button>
          <button class="chip" data-tag="end-to-end"><span data-tr>uçtan uca</span><span data-en hidden>end-to-end</span></button>
