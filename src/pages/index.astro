        </dd></dl>
      </div>
      <div class="filter-bar" id="filterBar">
        <span data-tr>filtre:</span><span data-en hidden>filter:</span>
        <span class="count" id="filterTag"></span>
        <span class="count" id="filterCount"></span>
        <button id="clearFilter" data-tr>temizle</button>
