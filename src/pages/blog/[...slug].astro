---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { author, SITE_URL } from '../../lib/identity';

export async function getStaticPaths() {
  const all = await getCollection('blog', ({ data }) =>
    import.meta.env.PROD ? !data.draft : true,
  );
  // tarihe göre eskiden yeniye sırala — docNumber için (dil bazında ayrı sayaç)
  const asc = [...all].sort(
    (a, b) => a.data.date.getTime() - b.data.date.getTime(),
  );
  const docCounter: Record<string, number> = {};

  return asc.map((entry) => {
    const lang = entry.data.lang ?? 'tr';
    docCounter[lang] = (docCounter[lang] ?? 0) + 1;

    // prev/next yalnızca aynı dilden — yeni-eski sıralı
    const sameLang = [...all]
      .filter((p) => (p.data.lang ?? 'tr') === lang)
      .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
    const idx = sameLang.findIndex((p) => p.id === entry.id);
    const newer = idx > 0 ? sameLang[idx - 1] : null;
    const older = idx < sameLang.length - 1 ? sameLang[idx + 1] : null;

    // translations map — diğer dilin entry'sini ekle
    const translationEntries: Record<string, { id: string; title: string }> = {};
    if (entry.data.translations) {
      for (const [code, slug] of Object.entries(entry.data.translations)) {
        const target = all.find((p) => p.id === slug);
        if (target) translationEntries[code] = { id: target.id, title: target.data.title };
      }
    }

    return {
      params: { slug: entry.id },
      props: {
        entry,
        docNumber: entry.data.docNumber ?? docCounter[lang],
        newer,
        older,
        translationEntries,
      },
    };
  });
}

interface Props {
  entry: CollectionEntry<'blog'>;
  docNumber: number;
  newer: CollectionEntry<'blog'> | null;
  older: CollectionEntry<'blog'> | null;
  translationEntries: Record<string, { id: string; title: string }>;
}

const { entry, docNumber, newer, older, translationEntries } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(entry);

const lang = (entry.data.lang ?? 'tr') as 'tr' | 'en';
const t = (tr: string, en: string) => (lang === 'en' ? en : tr);

const fmt = (d: Date) =>
  `${d.getFullYear()}·${String(d.getMonth() + 1).padStart(2, '0')}·${String(d.getDate()).padStart(2, '0')}`;

const docNo = String(docNumber).padStart(3, '0');
const dateStr = fmt(entry.data.date);
const updatedStr = entry.data.updated ? fmt(entry.data.updated) : null;

// kaba okuma süresi — 200 kelime/dk, dokümanın ham markdown body'si
const wordCount = entry.body?.split(/\s+/).filter(Boolean).length ?? 0;
const readMin = Math.max(1, Math.round(wordCount / 200));

// Google snippet için ayrı; verilmezse lede'nin ilk 155 karakteri
const metaDesc =
  entry.data.metaDescription ??
  (entry.data.lede ? entry.data.lede.slice(0, 155) : entry.data.title);

const postUrl = `${SITE_URL}/blog/${entry.id}`;
const ogImagePath = `/og/${entry.id}.png`;
const ogImageAbsolute = `${SITE_URL}${ogImagePath}`;

// hreflang alternates — yalnızca çevirisi olan post'larda. x-default = TR (ana dil).
const langCanon = lang === 'en' ? 'en' : 'tr';
const langSelfAndTranslations: Array<{ code: string; href: string }> = [
  { code: langCanon, href: postUrl },
  ...Object.entries(translationEntries).map(([code, target]) => ({
    code,
    href: `${SITE_URL}/blog/${target.id}`,
  })),
];
const trVersion = langSelfAndTranslations.find((l) => l.code === 'tr');
const alternates =
  Object.keys(translationEntries).length > 0 && trVersion
    ? [...langSelfAndTranslations, { code: 'x-default', href: trVersion.href }]
    : [];

const jsonLdGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: entry.data.title,
      description: metaDesc,
      image: [ogImageAbsolute],
      datePublished: entry.data.date.toISOString(),
      dateModified: (entry.data.updated ?? entry.data.date).toISOString(),
      inLanguage: lang === 'en' ? 'en' : 'tr-TR',
      author,
      publisher: author,
      url: postUrl,
      mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
      keywords: entry.data.tags.join(', '),
      wordCount,
      timeRequired: `PT${readMin}M`,
      articleSection: entry.data.tags[0] ?? 'blog',
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Talha Bekler',
          item: SITE_URL,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Blog',
          item: `${SITE_URL}/blog`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: entry.data.title,
          item: postUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  title={`${entry.data.title} — Talha Bekler`}
  description={metaDesc}
  ogTitle={entry.data.ogTitle ?? `${entry.data.title} — Talha Bekler`}
  ogDescription={metaDesc}
  ogType="article"
  ogImage={ogImagePath}
  ogImageAlt={entry.data.title}
  section="blog"
  breadcrumb={`blog/talha-bekler/${entry.id}`}
  metaTr={`${readMin} dk · ${dateStr}`}
  metaEn={`${readMin} min · ${dateStr}`}
  showLangToggle={false}
  jsonLd={jsonLdGraph}
  footOkTr={t('yazı sonu', 'end of post')}
  footOkEn={t('yazı sonu', 'end of post')}
  htmlLang={lang}
  alternates={alternates}
>
  {entry.data.draft && (
    <meta slot="head" name="robots" content="noindex,nofollow" />
  )}

  <article class="post">
    <div class="post-meta">
      <span>{t('belge', 'doc')}</span>
      <span class="v">BLOG—{docNo}</span>
      <span>{t('tarih', 'date')}</span>
      <span class="v">{dateStr}</span>
      {updatedStr && (
        <>
          <span>{t('güncel', 'updated')}</span>
          <span class="v">{updatedStr}</span>
        </>
      )}
      <span>{t('okuma', 'read')}</span>
      <span class="v">{readMin} {t('dk', 'min')}</span>
      {entry.data.tags.length > 0 && (
        <>
          <span>{t('etiket', 'tags')}</span>
          <span class="v tag">{entry.data.tags.join(' · ')}</span>
        </>
      )}
      {Object.keys(translationEntries).length > 0 && (
        <>
          <span>{t('çeviri', 'available in')}</span>
          <span class="v">
            {Object.entries(translationEntries).map(([code, target], i) => (
              <>
                {i > 0 && ' · '}
                <a href={`/blog/${target.id}`} style="color:var(--accent)" title={target.title}>
                  {code.toUpperCase()}
                </a>
              </>
            ))}
          </span>
        </>
      )}
    </div>
    <header class="post-head">
      <h1>{entry.data.title}</h1>
      {entry.data.lede && <p class="lede">{entry.data.lede}</p>}
    </header>
    <div class="prose">
      <Content />
    </div>
  </article>

  {(older || newer) && (
    <nav class="post-nav" aria-label={t('Yazılar arasında dolaşma', 'Post navigation')}>
      <div>
        {older ? (
          <a class="nav-prev" href={`/blog/${older.id}`}>
            ← {t('önceki', 'previous')}
            <span class="nav-title">{older.data.title}</span>
          </a>
        ) : <span></span>}
      </div>
      <div>
        {newer ? (
          <a class="nav-next" href={`/blog/${newer.id}`}>
            {t('sonraki', 'next')} →
            <span class="nav-title">{newer.data.title}</span>
          </a>
        ) : <span></span>}
      </div>
    </nav>
  )}
</BaseLayout>
